#!/bin/bash

### Load secrets from /root/.env.serverwatch
set -o allexport
source /root/.env.serverwatch
set +o allexport

### Prepare logging
logfile="/var/log/serverwatch.log"
exec >> "$logfile" 2>&1

echo "\n----- $(date '+%Y-%m-%d %H:%M:%S') -----" >> "$logfile"

### Variables
date=$(date +"%Y-%m-%d")
report_dir="/var/log/serverreport"
report_md="$report_dir/report_$date.md"
report_html="$report_dir/report_$date.html"
temp_dir="/tmp/serverreport_$date"
mkdir -p "$temp_dir" "$report_dir"

# List of critical services
dienste=(
  alertmanager clamav-daemon clamav-freshclam containerd cron docker fail2ban fluentd maldet nginx
  nginx-exporter node-exporter prometheus psono psonofileserver qemu-guest-agent sendmail ssh
  openvpn postgresql
)

# Log files
logfiles=(
  /var/log/ufw.log
  /var/log/openvpn.log
  /var/log/nginx/access.log
  /var/log/nginx/error.log
  /var/log/postgresql/postgresql-*.log
  /var/log/rkhunter.log
  /var/log/fail2ban.log
  /var/log/faillog
  /var/log/auth.log
  /var/log/clamav/clamav.log
  /var/log/syslog
)

# Dynamically add all audit.log files (without .gz)
for f in /var/log/psono/audit.log /var/log/psono/audit.log.[0-9]*; do
  [[ -f "$f" && "$f" != *.gz ]] && logfiles+=("$f")
done

### 1. Check services
echo "## Dienststatus" > "$temp_dir/services.md"
for service in "${dienste[@]}"; do
  echo -e "### $service\n\n\
  ```" >> "$temp_dir/services.md"
  systemctl status "$service" --no-pager >> "$temp_dir/services.md" 2>&1
  echo -e "\
  ```" >> "$temp_dir/services.md"
done

### 2. Etckeeper status
echo -e "## Etckeeper Status\n" > "$temp_dir/etckeeper.md"
cd /etc && etckeeper vcs status >> "$temp_dir/etckeeper.md"

### 3. Analyze logs
echo "## Logauswertungen" > "$temp_dir/logs.md"
for logfile in "${logfiles[@]}"; do
  echo -e "\n### $logfile\n\n\
  ```" >> "$temp_dir/logs.md"
  grep -i "error\|fail\|unauthorized\|blocked" "$logfile" 2>/dev/null | tail -n 20 >> "$temp_dir/logs.md"
  echo -e "\
  ```" >> "$temp_dir/logs.md"
done

### 4. Disk usage + cleanup
echo "## Festplattenstatus\n" > "$temp_dir/disk.md"
df -h >> "$temp_dir/disk.md"
echo "\n" >> "$temp_dir/disk.md"
echo "\n### /tmp aufräumen\n" >> "$temp_dir/disk.md"
find /tmp -type f -atime +5 -delete && echo "Temporäre Dateien gelöscht." >> "$temp_dir/disk.md"

### 5. RKHunter warnings
echo "## RKHunter Warnungen\n" > "$temp_dir/rkhunter.md"
grep -i warning /var/log/rkhunter.log >> "$temp_dir/rkhunter.md"
echo "\n" >> "$temp_dir/rkhunter.md"

### 6. Merge report
cat "$temp_dir/services.md" "$temp_dir/etckeeper.md" "$temp_dir/logs.md" "$temp_dir/disk.md" "$temp_dir/rkhunter.md" > "$report_md"

### 7. Python: GPT analysis + HTML mail with attachment
PYTHON_CMD="/opt/venv/bin/python3"
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
export PYTHONPATH="$SCRIPT_DIR:$PYTHONPATH"

$PYTHON_CMD << EOF
import sys
import os
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..'))

from serverwatch_analyzer import ServerAnalyzer, ReportGenerator

try:
    # Initialize analyzer and report generator
    analyzer = ServerAnalyzer()
    generator = ReportGenerator()

    # Get configuration from environment
    recipient = os.getenv("ALERT_RECIPIENT", "admin@example.com")
    hostname = os.getenv("HOSTNAME", "localhost")
    report_path = "$report_md"
    html_path = "$report_html"
    date_str = "$date"

    # Read report content
    with open(report_path, "r", encoding="utf-8") as f:
        logdata = f.read()

    # Analyze report
    analysis = analyzer.analyze_report(logdata)

    # Process complete report (append analysis, convert to HTML, send email)
    generator.process_report(
        report_path,
        html_path,
        analysis,
        recipient,
        hostname,
        date_str
    )

    print("Report analysis and processing completed successfully")

except Exception as e:
    print(f"Error in report processing: {str(e)}")
    # Fallback: at least append a basic error message to the report
    with open(report_path, "a", encoding="utf-8") as f:
        f.write(f"\n\n## Analysis Error\nFailed to analyze report: {str(e)}")
    sys.exit(1)

EOF

### 8. Send email (handled by Python module above, but keep mutt as fallback)
# The Python module handles email sending, but we keep this as a fallback option
# cat "$report_html" | mutt -s "[${HOSTNAME}]:Daily Server Report $date" -e "set content_type=text/html" "$ALERT_RECIPIENT" -a "$report_md"

exit 0
